<service>
  <id>SDKAnalyzer</id>
  <name>SDK Analyzer</name>
  <description>Analisador de Logs SDK Senior</description>
  <executable>java</executable>
  <arguments>-jar "%BASE%\..\sdk-analyzer.jar" --spring.config.additional-location=file:%BASE%\..\config.properties</arguments>
  <startmode>Manual</startmode>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>3</keepFiles>
  </log>
</service>
